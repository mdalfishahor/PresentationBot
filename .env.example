# ─── Discord Bot Token ────────────────────────────────────────────────────────
# Get this from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# ─── Application / Client ID ──────────────────────────────────────────────────
# Found in the same developer portal under OAuth2 > General
CLIENT_ID=your_client_id_here

# ─── Guild (Server) ID ────────────────────────────────────────────────────────
# Right-click your server icon → Copy Server ID
# (Requires Developer Mode in Discord settings)
GUILD_ID=your_guild_id_here

# ─── Role IDs ─────────────────────────────────────────────────────────────────
# Create each role in Server Settings → Roles.
# Right-click a role → Copy ID.
VERIFIED_ROLE_ID=role_id_for_verified
IBCC_ROLE_ID=role_id_for_ibcc
CF_ROLE_ID=role_id_for_cf
ENG_ROLE_ID=role_id_for_eng
MATH101_ROLE_ID=role_id_for_math101

# ─── Channel IDs ──────────────────────────────────────────────────────────────
# Right-click a channel → Copy ID.
VERIFY_CHANNEL_ID=channel_id_for_verify
LOG_CHANNEL_ID=channel_id_for_verification_log
